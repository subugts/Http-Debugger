{
  "name": "http-debugger",
  "version": "1.0.0",
  "description": "A powerful HTTP/HTTPS traffic debugger and analyzer with clean UI - proxy-based HTTP sniffer for debugging API calls",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.httpdebugger.app",
    "productName": "HTTP Debugger",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "http",
    "debugger",
    "sniffer",
    "proxy",
    "api",
    "network",
    "traffic",
    "analyzer"
  ],
  "author": "HTTP Debugger",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
